NEXT_PUBLIC_API_URL=http://localhost:8000
# Optional: used if auth pages render on server; browser uses window.location.origin for password reset redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Supabase — must be the SAME project as apps/api .env (SUPABASE_URL + SUPABASE_KEY).
# Use the legacy "anon" "public" JWT key from Dashboard → Settings → API (starts with eyJ...).
# Do not use sb_publishable_... here unless Supabase docs say it replaces anon for your SDK; mismatch with API causes 401 on /profile/me.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
